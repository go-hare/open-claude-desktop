{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "node",
      "electron"
    ],
    "baseUrl": ".",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "electron/**/*.ts",
    "shared/**/*.ts",
    "vite.*.config.ts"
  ],
  "exclude": [
    ".vite",
    "out",
    "dist",
    "node_modules"
  ]
}
